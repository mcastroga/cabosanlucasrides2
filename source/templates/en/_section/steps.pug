style.
    .act {
        padding: 2rem 2.5rem;
        background: #f2ede4;
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
        transition: background .4s, transform .4s
    }

    .act:hover {
        background: var(--accent-light);
        transform: translate(4px)
    }

    .act-num {
        font-family: var(--serif);
        font-size: 2.5rem;
        font-weight: 300;
        color: var(--accent-light);
        line-height: 1;
        flex-shrink: 0;
        width: 50px;
        transition: color .4s
    }

    .act:hover .act-num {
        color: var(--accent-roast)
    }

    .act-text h4 {
        font-family: var(--serif);
        font-size: 1.05rem;
        font-weight: 400;
        margin-bottom: .5rem
    }

    .act-text p {
        font-size: .82rem;
        font-weight: 300;
        color: var(--text-mid);
        line-height: 1.7
    }
    .act-item { transition: opacity 0.3s; }
    .act-item:hover { opacity: 0.8; }
    .text-primary { color: #C04B20 !important; }
