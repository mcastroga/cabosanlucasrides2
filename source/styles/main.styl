body
    background #fff
    font-family "Miranda Sans", sans-serif

    a
      text-decoration: none

    h2, h3, h4, h5, h6
      font-family "Raleway", serif;

    .background-color-1
      background-color #F7F7F7

    @require '_variables/colors.styl'
    @require '_variables/fonts.styl'
    @require '_partials/footer.styl'
    @require '_sections/banners.styl'
    @require '_sections/zones.styl'
    @require '_sections/welcome.styl'
    @require '_sections/mycabotransfers.styl'

    .text-right
        text-align right
    .text-left
        text-align left
    .margin-right-10
      margin-right 10px
    .box-textimonial
      margin 0 auto
      min-height 250px
      width 70%
    .height-100
      height 100%

  section#blog-index
    background-color #4d4d4d
    padding 30px 0 0
    position relative

    .card
      margin-bottom 30px

      a, p
        color #000

      .card-title
        color #000
        display -webkit-box
        -webkit-line-clamp 2
        -webkit-box-orient vertical
        min-height 48px
        overflow hidden
        text-overflow ellipsis

      .card-text
        display -webkit-box
        -webkit-line-clamp 3
        -webkit-box-orient vertical
        font-size 16px
        height 76px
        margin 0
        overflow hidden
        padding 0
        text-overflow ellipsis

    @media(max-width: 767px)
      h2
        font-size 22px
      p
        font-size 18px

body.hotels
  background-color #fff
  section.banner
    margin-top 130px

  section.article
    margin-bottom 30px
    margin-top 30px

  section.transportation
    margin-bottom 40px

  section.contact
    margin-top 40px

  section.maps
    margin 40px 0

  h1, h2,h3, h4, h5, h6
    color #000
    text-align left

  h1
    font-size 32px
    padding-bottom 30px

  h2
    font-size 30px

  h3
    font-size 28px
    font-weight 600

  ul
    padding-left 2rem

  section.introduction
    margin-top 30px

  section#mycabotransfers
    margin-top 0

section#separator-1,
section#separator-2
  background-color #fff
  padding 40px 0

@media (min-width: 1200px)
  .col-xl
    flex: 1 0 0% !important

@media (max-width: 1199px)
  section#zones .fix-mobile-margin-bottom
    margin-bottom: 30px