#banner
  position relative

  .carousel-item
    .img-banner
      height 1000px
      width 100%
    .img-01
      background url("/images/banners/transportation-for-less-01.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center
    .img-02
      background url("/images/banners/transportation-for-less-02.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center
    .img-03
      background url("/images/banners/transportation-for-less-03.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center
    .img-04
      background url("/images/banners/transportation-for-less-04.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center
    .img-05
      background url("/images/banners/transportation-for-less-05.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center
    .img-06
      background url("/images/banners/transportation-for-less-06.jpg")
      background-repeat no-repeat
      background-size contain
      background-position center


  .carousel-indicators
    margin-bottom 30px

    button
      background-color $color-blue-2
      border 0
      border-radius 50%
      margin-left 3px
      margin-right 3px
      height 20px
      opacity 1
      width 20px

  .carousel-indicators
    button.active
      background-color $color-blue-1

@media (max-width 2080px)
  #banner
    .carousel-item
      .img-banner
        height 1000px
      .img-01, .img-02, .img-03, .img-04, .img-05, .img-06
        background-size cover

@media (max-width 1700px)
  #banner
    .carousel-item
      .img-banner
        height 900px

@media (max-width 1500px)
  #banner
    .carousel-item
      .img-banner
        height 700px

@media (max-width 1200px)
  #banner
    .carousel-item
      .img-banner
        height 500px

@media (max-width 1080px)
  #banner
    #menu-banner
      img.main-logo
        height 300px

@media (max-width 767px)
  #banner
    .carousel-item
      .img-banner
        height 400px
    .carousel-indicators
      display none

section#activities
  h3
    margin-top 0
    padding-top 0
  img
    border-radius 15px

section#promo
  background #fff
  padding 30px 0

  h2
    padding 20px 0

  a
    color #fff
    padding 10px

section#contact-us,
section#cabo-information,
section#about-us,
section#our-services
  padding 130px 0 30px

  .purple-box
    background-color #bcadce
    padding 30px

    a
      color #fff
      display block
      font-size 22px
      text-decoration none

    h2, h3, h4, p
      color #fff

    a, p
      margin-bottom 10px

section#about-us
  .profile-image
    align-items center
    display flex
    height 400px
    justify-content center