section#testimonials
  background-color $color-blue-1
  color #fff
  padding 30px 0

  .quote-left
    color #fff
    font-size 40px
    text-align left

  .quote-right
    color #fff
    font-size 40px
    text-align right

  .carousel-indicators
    position relative

  .testimonial-text
    min-height 320px
    overflow hidden
    padding 10px
    position relative

    p
      color #fff
      display -webkit-box
      -webkit-line-clamp 8
      -webkit-box-orient vertical
      font-size 20px
      font-style italic
      overflow hidden
      text-align left
      text-overflow ellipsis

    a.fixed-link
      position absolute
      right 8px
      top 5px

  .testimonial-bottom
    margin 5px 0 30px
    text-align center
    width 100%

    .testimonial-stars
      color $color-white-2
      display inline-flex
      font-size 30px
      margin-bottom 30px

      svg
        padding 0 5px

  .user-image
    border 4px solid #fff
    border-radius 50%
    display flex
    height 64px
    margin 0 auto 20px
    overflow hidden
    width 64px

    img
      margin 0

  .user-data
    .name
      font-size 20px
      font-weight bold

  img
    margin-bottom 20px

  p
    strong
      display -webkit-box
      -webkit-line-clamp 3
      -webkit-box-orient vertical
      margin-bottom 15px
      overflow hidden
      text-align center
      text-overflow ellipsis
      width 100%

  a, p
    color #fff
    font-size 24px
    text-decoration none

  @media(max-width: 575px)
    .testimonial-text
      height auto
      margin 30px
    .testimonial-bottom
      margin 0
