section#footer
  background-color #6d6e70
  font-size 14px
  padding 30px 0
  text-decoration none

  .theme-page-footer-top
    padding-bottom 30px

  .theme-page-footer-top,
  .theme-page-footer-middle,
  .theme-page-footer-bottom
    p
      color #fff
      font-size 20px
      padding 20px 0

  .theme-page-footer-bottom
    border-top 1px solid #fff
    padding-top 30px

    p
      margin 0
      padding 0

      a
        display block
        font-size 18px
        font-weight 400
        overflow hidden
        text-overflow ellipsis
        white-space nowrap

    svg
      color #fff
      padding 0 10px


  .theme-component-feature-item
    display inline-flex
    border-bottom 1px solid #fff
    padding 0 0 15px

    .theme-component-feature-item-icon
      color: #fff
      font-size: 28px;
      padding: 0 10px 0 0;

    .theme-component-feature-item-header
      align-items center
      color #fff
      display flex
      font-family: 'Roboto';
      font-size 16px
      font-weight: 400;
      text-transform: uppercase;
      line-height: 24px;
      letter-spacing: 2px;

  p
    color #fff
    font-size 24px
    margin 0 0 15px

  a
    color #fff
    font-size 20px
    font-weight 700
    text-decoration none
  i
    color #fff

@media(max-width 991px){
  section#footer {
    .theme-page-footer-bottom {
      p {
        span {
          display: none;
        }
      }
    }
  }
}

@media(max-width 767px){
  section#footer {
    .theme-page-footer-top {
      .footer-logo {
        margin-bottom 30px
        text-align center

        img {
          max-width 300px
        }
      }
    }
  }
  section#design {
    height 60px

    .design {
      text-align left
    }
  }
}

.whatsapp-circle
  background-color #25d366
  border 2px solid #fff
  border-radius 50%
  bottom 15px
  height 80px
  position fixed
  right 15px
  width 80px

  a
    align-items center
    color #fff
    display flex
    font-size 50px
    height 80px
    justify-content center

