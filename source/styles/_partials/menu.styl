section#top-menu
  background #fff
  border-bottom 1px solid #000
  position fixed
  top 0
  width 100%
  z-index 999

  #menu
    background-color transparent
    height 100px
    width 100%
    z-index 6

    .navbar-collapse
      height 100%

    .navbar
      height 100px
      padding 10px 0


    .navbar-brand
      background url('/images/logo/transportation-for-less-rectangle.svg')
      background-repeat no-repeat
      background-size cover
      height 80px
      margin 10px 0
      min-width 362px
      padding 0

      a
        display block
        height 60px
        padding 0

    .elementor-button
      align-items center
      background-color $color-purple
      border 2px solid $color-purple
      border-radius 30px
      color #fff
      display inline-flex
      line-height 48px
      padding 0 20px
      text-decoration none

      .elementor-button-content-wrapper
        align-items center
        display flex
        height auto

        .elementor-icon
          font-size 16px
          margin-right 10px

        .elementor-text
          font-size 16px

    .elementor-button:hover
      background-color white
      color $color-purple

    .navbar-nav
      padding-bottom 0
      .nav-link
        color $color-gray
        font-size 20px
        font-weight 400
        padding 0
        text-transform uppercase

      .nav-item
        line-height 80px
        padding-left 0
        padding-right 40px


      .nav-item:last-child
        padding-right 0

    @media (max-width 1280px)
      .navbar-nav
        .nav-link
          font-size 18px

        .nav-item
          padding-right 30px

    @media (max-width 1199px)
      .navbar-nav
        .nav-link
          font-size 16px
        .nav-item
          padding-right 20px

      .elementor-button
        padding 0 15px

        .elementor-button-content-wrapper
          .elementor-icon
            font-size 14px
        .elementor-text
          font-size 14px

@media (max-width 1399px)
  section#top-menu
    section#menu
      .navbar-brand
        height 60px
        min-width 272px

@media (max-width 1199px)
  section#top-menu
    section#menu
      .navbar-brand
        background url('/images/logo/transportation-for-less-small.svg')
        background-size cover
        height 60px
        min-width 60px

@media (max-width 991px)
  section#top-menu
    background-color #fff !important
    section#menu
      .navbar-brand
        background url('/images/logo/transportation-for-less-rectangle.svg')
        background-repeat no-repeat !important
        background-size cover !important
        height 60px
        min-width 272px
      .navbar-nav
        border 1px solid #000
        padding-bottom 10px
        .nav-item
          line-height 50px
          padding 0
          text-align center
        .nav-link
          color #000 !important

      .navbar-collapse
        background-color #ffffff !important

@media (max-width 420px)
  section#top-menu
    section#menu
      .navbar-brand
        background url('/images/logo/transportation-for-less-rectangle.svg')
        background-repeat no-repeat !important
        background-size cover !important
        min-width auto
        overflow hidden
        width 80px